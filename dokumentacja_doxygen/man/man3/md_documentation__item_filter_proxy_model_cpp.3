.SH NAME
md_documentation__item_filter_proxy_model_cpp \- Dokumentacja dla pliku \fC\fBItemFilterProxyModel\&.cpp\fP\fP 

.SH "Metadane"
.PP
.IP "\(bu" 2
\fBPlik\fP: \fBItemFilterProxyModel\&.cpp\fP
.IP "\(bu" 2
