.PP

.IP "4." 4
\fBMetody prywatne\fP 
.br
.IP "  \(bu" 4
\fCverifyDatabaseSchema\fP: Weryfikuje schemat bazy danych\&.
.IP "  \(bu" 4
\fCcreateDatabaseSchema\fP: Tworzy schemat bazy danych\&.
.IP "  \(bu" 4
\fCinsertSampleData\fP: Wstawia przykładowe dane\&.
.IP "  \(bu" 4
\fCinitFilters\fP: Inicjalizuje filtry combo boxów\&.
.IP "  \(bu" 4
\fCrefreshFilters\fP: Odświeża filtry combo boxów\&.
.IP "  \(bu" 4
\fCupdateFilterComboBoxes\fP: Odbudowuje listy combo boxów dla filtrowania kaskadowego\&.
