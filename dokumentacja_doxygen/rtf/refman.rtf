54 {\cf17 class }ZoomableGraphicsView : {\cf17 public} QGraphicsView\par
55 \{\par
56     Q_OBJECT\par
57 {\cf17 public}:\par
67     {\cf17 explicit} ZoomableGraphicsView(QWidget *parent = {\cf17 nullptr})\par
68         : QGraphicsView(parent)\par
69         , m_scaleFactor(1.0)\par
70     \{\par
71         setTransformationAnchor(QGraphicsView::AnchorUnderMouse);\par
72         setDragMode(QGraphicsView::ScrollHandDrag);\par
73     \}\par
74 \par
75 {\cf17 protected}:\par
86     {\cf18 void} wheelEvent(QWheelEvent *event){\cf17  override}\par
87 {\cf17     }\{\par
88         {\cf17 constexpr} {\cf18 double} zoomInFactor = 1.15;\par
89         {\cf17 constexpr} {\cf18 double} zoomOutFactor = 1.0 / zoomInFactor;\par
90 \par
91         {\cf19 if} (event->angleDelta().y() > 0) \{\par
92             scale(zoomInFactor, zoomInFactor);\par
93             m_scaleFactor *= zoomInFactor;\par
94         \} {\cf19 else} \{\par
95             scale(zoomOutFactor, zoomOutFactor);\par
96             m_scaleFactor *= zoomOutFactor;\par
97         \}\par
98         {\cf17 event}->accept();\par
99     \}\par
100 \par
101 {\cf17 private}:\par
103     {\cf18 double} m_scaleFactor;\par
104 \};\par
